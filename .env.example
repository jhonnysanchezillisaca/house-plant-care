# Session secret - generate a secure random string for production (min 32 characters)
NUXT_SESSION_PASSWORD=change-me-to-a-secure-random-string-at-least-32-characters

# Trefle API token (optional) - get free token at https://trefle.io
# Used for plant species search with images
TREFLE_API_TOKEN=your-trefle-api-token